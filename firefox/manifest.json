{
  "manifest_version": 2,
  "name": "Jira Links",
  "version": "1.0.0",
  "description": "Hover over Jira ticket IDs to get quick links to your Jira instance.",
  "permissions": ["storage"],
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jira-links@extension"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["constants.js", "storage.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
